# ============================================================
# NSE Analytics Platform - .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-log.txt

# --- Virtual Environments ---
venv/
env/
.venv/
ENV/

# --- Environment / Secrets ---
.env
.env.local
.env.*.local
secrets.yaml

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Data Files (too large for git) ---
data/raw/*
data/processed/*
data/archive/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/archive/.gitkeep
*.csv
*.zip
*.parquet
*.feather

# --- Logs ---
logs/
*.log

# --- Database ---
*.db
*.sqlite
*.sqlite3

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Documentation builds ---
docs/_build/
site/

# --- Streamlit ---
.streamlit/secrets.toml